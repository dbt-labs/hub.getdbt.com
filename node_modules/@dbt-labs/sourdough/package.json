{
  "name": "@dbt-labs/sourdough",
  "version": "18.12.1",
  "description": "shared components for dbt Labs UIs",
  "main": "./dist/sourdough.js",
  "type": "module",
  "types": "./dist/sourdough.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sourdough.d.ts",
      "import": "./dist/sourdough.js",
      "require": "./dist/sourdough.cjs"
    },
    "./tailwind.config": "./tailwind.config.cjs",
    "./dist/*.css": {
      "import": "./dist/*.css",
      "require": "./dist/*.css"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/dbt-labs/bakery.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/dbt-labs/bakery/issues"
  },
  "homepage": "https://github.com/dbt-labs/bakery/tree/main/packages/sourdough#readme",
  "dependencies": {
    "@floating-ui/react": "^0.27.16",
    "@headlessui/react": "1.7.18",
    "@hookform/resolvers": "4.1.3",
    "@tailwindcss/forms": "^0.5.3",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.6",
    "allotment": "^1.20.4",
    "ansi-to-html": "^0.7.2",
    "d3": "^7.0.3",
    "d3-axis-for-react": "^1.1.1",
    "date-fns": "^3.6.0",
    "dompurify": "^3.2.4",
    "focus-visible": "^5.2.0",
    "merge-refs": "^2.0.0",
    "prism-react-renderer": "^2.4.0",
    "react-datepicker": "^8.7.0",
    "react-dnd": "^16.0.0",
    "react-dnd-html5-backend": "^16.0.1",
    "react-hook-form": "7.54.2",
    "react-hot-toast": "^2.4.1",
    "react-resize-detector": "^12.0.2",
    "react-select": "^5.10.1",
    "react-use": "^17.3.2",
    "react-virtualized-auto-sizer": "^1.0.26",
    "react-vtree": "^3.0.0-beta.3",
    "react-window": "^1.8.11",
    "smoothscroll-polyfill": "^0.4.4",
    "tailwind-merge": "^1.14.0",
    "validator": "^13.7.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-react": "^7.23.3",
    "@babel/types": "^7.23.9",
    "@cypress/code-coverage": "^3.12.24",
    "@cypress/vite-dev-server": "^7.0.0",
    "@storybook/addon-docs": "^8.6.12",
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/addon-storysource": "^8.6.12",
    "@storybook/addon-themes": "^8.6.12",
    "@storybook/blocks": "^8.6.12",
    "@storybook/builder-vite": "^8.6.12",
    "@storybook/icons": "^1.4.0",
    "@storybook/manager-api": "^8.6.12",
    "@storybook/preview-api": "^8.6.12",
    "@storybook/react": "^8.6.12",
    "@storybook/react-vite": "^8.6.12",
    "@storybook/theming": "^8.6.12",
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@tanstack/react-query": "^5.74.4",
    "@types/babel__core": "^7.20.5",
    "@types/d3": "^7.0.0",
    "@types/node": "^22.15.18",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@types/react-window": "^1.8.8",
    "@types/validator": "^13.7.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.20",
    "babel-plugin-react-compiler": "1.0.0",
    "classnames": "^2.3.1",
    "concurrently": "^9.1.2",
    "cypress": "15.2.0",
    "cypress-real-events": "^1.15.0",
    "eslint-plugin-sentence-case": "^0.0.6",
    "nodemon": "^2.0.22",
    "postcss": "^8.4.35",
    "postcss-focus-visible": "^7.1.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-router": "^6.23.0",
    "react-router-dom": "^6.23.0",
    "remark-gfm": "^4.0.0",
    "storybook": "^8.6.12",
    "tsx": "^4.20.0",
    "typescript": "^5.5.4",
    "vite": "^5.3.3",
    "vite-plugin-dts": "^3.6.4",
    "vite-plugin-externalize-deps": "^0.8.0",
    "vite-plugin-istanbul": "^5.0.0",
    "vite-plugin-svgr": "^4.2.0",
    "vite-tsconfig-paths": "^4.2.1",
    "@dbt-labs/eslint-config": "3.0.1",
    "@dbt-labs/biga": "1.7.1",
    "@dbt-labs/eslint-plugin-biga": "9.1.1",
    "@dbt-labs/prettier-config": "0.1.2",
    "@dbt-labs/tsconfig": "1.0.0"
  },
  "peerDependencies": {
    "@dbt-labs/biga": ">=0.2",
    "classnames": "*",
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0",
    "react-router": "*",
    "react-router-dom": "*",
    "tailwindcss": "^3.4.1"
  },
  "scripts": {
    "alpha": "pnpm dlx @dbt-labs/publish-alpha",
    "build:local-dev": "pnpm build:compile && pnpm build:types",
    "build:types": "tsc -p tsconfig.release.json",
    "build:storybook": "storybook build",
    "build:compile": "NODE_OPTIONS='--max_old_space_size=8192' vite build",
    "build": "pnpm build:compile",
    "build:watch": "vite build --watch",
    "changeset": "echo \"NOOP: changeset must be run from the bakery directory\"",
    "clean:cache": "rm -rf ./dist node_modules/.vite node_modules/.cache",
    "coverage:cypress": "pnpm test:cypress && pnpm --silent dlx nyc report --reporter=text",
    "dev:types": "tsc -p tsconfig.release.json --watch",
    "dev": "pnpm start",
    "dev:force": "pnpm clean:cache && pnpm dev",
    "dev:watch": "export LOCAL_DEV=true && nodemon --watch 'src/*' --ext ts,tsx,css --exec 'pnpm build:local-dev'",
    "format": "pnpm prettier --config ./.prettierrc.js --ignore-unknown --write ./src/**/*",
    "ryecons:generate:watch": "nodemon --exec \"pnpm ryecons:generate\" --watch src/components/ryecons/svg -e svg",
    "ryecons:generate": "tsx src/scripts/ryecons/runner.ts",
    "link:cloud-ui": "pnpm link .",
    "lint-fix": "pnpm lint --fix",
    "lint-fix:debug": "pnpm lint --fix --debug",
    "lint": "eslint ./src --ext .ts,.tsx,.js,.mjs,.cjs --max-warnings 0",
    "local-dev": "tsx scripts/local-dev/runner.ts",
    "start": "storybook dev -p 6006",
    "start:ci": "CI=true storybook dev -p 6006",
    "test": "pnpm test:cypress && pnpm test:ryecons",
    "test:cypress": "pnpm cypress run --component --browser chrome",
    "test:cypress:debug": "DEBUG=cypress:* pnpm cypress run --component",
    "test:ryecons": "pnpm ryecons:generate --ci",
    "test:cypress:dev": "pnpm cypress open --component --browser chrome",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  }
}