{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@dbt-labs/tsconfig/base.json",
  "compilerOptions": {
    "baseUrl": "./src",
    "lib": ["ESNext"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "ESNext",
    "outDir": "./dist",
    "types": ["node"]
  },
  "include": ["src/"]
}
