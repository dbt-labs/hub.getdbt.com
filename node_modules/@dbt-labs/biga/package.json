{
  "name": "@dbt-labs/biga",
  "version": "1.7.1",
  "description": "Design Tokens for UIs across dbt Labs",
  "main": "src/build.ts",
  "type": "module",
  "author": "",
  "license": "ISC",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "import": "./tokens/tokens.js",
      "require": "./tokens/tokens.cjs"
    },
    "./*.css": {
      "import": "./tokens/*.css",
      "require": "./tokens/*.css"
    },
    "./*.js": {
      "import": "./tokens/*.js",
      "require": "./tokens/*.cjs"
    }
  },
  "devDependencies": {
    "@types/lodash.camelcase": "^4.3.9",
    "@types/node": "^22.15.18",
    "concurrently": "^9.1.2",
    "lodash.camelcase": "^4.3.0",
    "style-dictionary": "^4.0.1",
    "tsx": "^4.20.0",
    "@dbt-labs/eslint-config": "3.0.1",
    "@dbt-labs/prettier-config": "0.1.2",
    "@dbt-labs/tsconfig": "0.1.0"
  },
  "scripts": {
    "alpha": "pnpm version prerelease --preid=alpha --no-commit-hooks || true; turbo run build && pnpm publish --no-git-checks --tag alpha",
    "build": "rm -rf ./dist && tsc --project tsconfig.json && node dist/build.js",
    "watch:tokens": "node --watch-path=design-assets dist/build.js",
    "watch:src": "tsc --project tsconfig.json --watch",
    "dev": "concurrently \"pnpm watch:src\" \"pnpm watch:tokens\"",
    "lint": "eslint . --fix",
    "format": "prettier --write src/* tokens/*",
    "typecheck": "tsc --noEmit"
  }
}