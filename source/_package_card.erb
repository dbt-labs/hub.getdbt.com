<% featured = (defined?(featured_context) && featured_context) ? true : false %>
<% tile_cfg = (defined?(featured_config) && featured_config) ? featured_config : nil %>
<% tile_desc = featured && tile_cfg && tile_cfg['description'].to_s.strip %>
<% tile_stars = featured && tile_cfg && tile_cfg['stars'].to_s.strip %>
<% tile_updated = featured && tile_cfg && tile_cfg['updated'].to_s.strip %>
<% version_label = package.latest.to_s.start_with?('v') ? package.latest.to_s : "v#{package.latest}" %>
<% logo_src = featured ? 'logos/featured_package_icon.svg' : package.assets.logo %>

<a href="/<%= package.namespace %>/<%= package.name %>/latest/" class="tile<%= ' tile--featured' if featured %>">
  <div class="tile-content">
    <div class="tile-body tile-body--package-card<%= ' tile-body--package-card-featured' if featured %>">
      <div class="tile-body__main">
        <div class="tile-graphic tile-graphic--package-card<%= ' tile-graphic--featured-card' if featured %>" aria-hidden="true">
          <%= image_tag(logo_src, { alt: '', class: 'tile-package-logo' }) %>
        </div>
        <div class="tile-body__intro">
          <h4 class="tile-package-name<%= ' tile-package-name--featured' if featured %>"><%= package.name %></h4>
          <% if featured %>
            <%# Figma 470:5042 — description slot is always 3 lines (54px) for grid alignment %>
            <p class="tile-package-desc"><%= tile_desc if tile_desc.present? %></p>
          <% elsif tile_desc.present? %>
            <p class="tile-package-desc"><%= tile_desc %></p>
          <% end %>
        </div>
      </div>
      <div class="tile-body__lower">
        <% if featured %>
          <div class="tile-body__meta" aria-label="Package stats">
            <% if tile_stars.present? %>
              <span class="tile-meta__group tile-meta__stars">
                <svg class="tile-meta-icon tile-meta-icon--star" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M5.53.37c.18-.53.92-.53 1.1 0l.83 2.45a.6.6 0 0 0 .55.4h2.58c.56 0 .79.7.34 1.04l-2.09 1.52a.6.6 0 0 0-.22.66l.8 2.46c.18.54-.44.98-.9.65L6.08 8.18a.6.6 0 0 0-.7 0l-2.43 1.77c-.46.33-1.08-.11-.9-.65l.8-2.46a.6.6 0 0 0-.22-.67L.11 4.27C-.34 3.92-.1 3.23.45 3.23h2.58a.6.6 0 0 0 .55-.4L4.4.37Z" fill="currentColor"/></svg>
                <span class="tile-meta__stars-count"><%= tile_stars %></span>
              </span>
            <% end %>
            <span class="tile-meta__rest">
              <% if tile_updated.present? %>
                <span class="tile-meta__group">
                  <svg class="tile-meta-icon tile-meta-icon--calendar" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M3.75 1v1h-.5A1.25 1.25 0 0 0 2 3.25v6.5C2 10.44 2.56 11 3.25 11h5.5c.69 0 1.25-.56 1.25-1.25v-6.5C10 2.56 9.44 2 8.75 2h-.5V1h-1v1h-3V1h-1Zm-1 3h7v5.75a.25.25 0 0 1-.25.25h-6.5a.25.25 0 0 1-.25-.25V4Z" fill="currentColor"/></svg>
                  <span class="tile-meta__muted"><%= tile_updated %></span>
                </span>
              <% end %>
              <span class="tile-meta__group">
                <span class="tile-meta__dot" aria-hidden="true"></span>
                <span class="tile-meta__muted tile-meta__version"><%= version_label %></span>
              </span>
            </span>
          </div>
        <% end %>
        <% if is_fusion_compatible(package) %>
          <%= partial "package_card_fusion_badge", locals: { variant: :full } %>
        <% elsif is_fusion_parse_compatible(package) %>
          <%= partial "package_card_fusion_badge", locals: { variant: :parse } %>
        <% end %>
      </div>
    </div>
  </div>
</a>
